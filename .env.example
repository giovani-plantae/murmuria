# murmuria — configuration.
# These are the defaults; `cp .env.example .env` activates them as-is. Edit any
# value, or comment a line out to fall back to the built-in default.

# Path to the ggml model file. Download it with `just model`.
MURMURIA_MODEL=models/ggml-large-v3-turbo-q5_0.bin

# Forced transcription language (whisper code: en, pt, es, fr, …).
MURMURIA_LANGUAGE=en

# Port you reach the server on. A set value pins it; comment it out to scan
# upward from 8000 for a free port. Under Docker it's the published host port.
MURMURIA_PORT=8000

# Force CPU even on a GPU build. Set to 1 to enable.
MURMURIA_CPU=0

# IP advertised over mDNS. Unset = auto-detect the primary LAN IP (recommended).
# Set it to pin a specific interface on multi-homed hosts (Docker/VPN), so
# clients don't get an unreachable 172.x bridge address.
# MURMURIA_ADVERTISE_IP=192.168.0.111
